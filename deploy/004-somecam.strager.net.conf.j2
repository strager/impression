# Redirects all somecam.strager.net traffic to impression.strager.net,
# preserving the request path.

<VirtualHost *:80>
	ServerName somecam.strager.net
	RewriteEngine on
	RewriteRule ^ https://impression.strager.net%{REQUEST_URI} [END,NE,R=permanent]
</VirtualHost>

<IfModule mod_ssl.c>
<VirtualHost *:443>
	ServerName somecam.strager.net

	RewriteEngine on
	RewriteRule ^ https://impression.strager.net%{REQUEST_URI} [END,NE,R=permanent]

	SSLCertificateFile /etc/letsencrypt/live/somecam.strager.net/fullchain.pem
	SSLCertificateKeyFile /etc/letsencrypt/live/somecam.strager.net/privkey.pem
	Include /etc/letsencrypt/options-ssl-apache.conf
</VirtualHost>
</IfModule>

