{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"erasableSyntaxOnly": true,
		"rewriteRelativeImportExtensions": true,
		"types": ["node"],
		"lib": ["ESNext"],
		"paths": {
			"rollup-plugin-license": ["./types/rollup-plugin-license.d.ts"]
		}
	},
	"include": ["backend/**/*.ts", "shared/**/*.ts", "tools/**/*.ts", "types/**/*.d.ts", "vite.config.ts", "vitest.config.ts"]
}
